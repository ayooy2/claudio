{
  "name": "claudio",
  "version": "2.0.0",
  "private": true,
  "description": "Claudio — 个人AI音乐电台",
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently -n api,server,client -c cyan,green,yellow \"npm run dev:api\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:api": "cd netease-api && npm start",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w server && npm run build -w client",
    "docker:build": "docker build -t claudio -f docker/Dockerfile .",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
