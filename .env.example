# Claudio 电台配置

# 服务器端口
PORT=8080
NODE_ENV=development

# Mock 开关 — 设为 false 后需填入真实 API Key
USE_MOCK_MUSIC=true
USE_MOCK_TTS=true
USE_MOCK_WEATHER=true
USE_MOCK_CALENDAR=true
USE_MOCK_UPNP=true

# 网易云音乐 API (NeteaseCloudMusicApi 服务地址)
NETEASE_API_BASE=http://localhost:3000

# Fish Audio TTS
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# OpenWeather
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Beijing

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# UPnP 设备名称
UPNP_DEVICE_NAME=
