# ===== Claudio 电台配置 =====

# 基础配置
PORT=8080
NODE_ENV=development

# Mock 开关（生产环境全部设 false）
USE_MOCK_MUSIC=false
USE_MOCK_TTS=false
USE_MOCK_WEATHER=false
USE_MOCK_CALENDAR=false
USE_MOCK_UPNP=false

# 网易云音乐 API（必填）
# 线上部署时改为你的 NeteaseCloudMusicApi 服务地址
NETEASE_API_BASE=http://localhost:3000
NETEASE_COOKIE=

# AI 大脑（必填 — DeepSeek 兼容接口）
BRAIN_API_URL=https://api.deepseek.com
BRAIN_API_KEY=sk-your-key-here
BRAIN_MODEL=deepseek-chat

# TTS 语音合成（二选一）

# 方案1: Fish Audio
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# 方案2: 阿里云
ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=
ALI_TTS_APP_KEY=

# 天气服务（可选）
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Beijing

# 飞书日历（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# UPnP 投屏（可选，仅局域网有效）
UPNP_DEVICE_NAME=Claudio

# ===== 前端环境变量 =====
# 生产环境填写后端地址，开发环境留空（走 Vite proxy）
VITE_API_BASE=
